# ===========================================================================
# IntelliAdmit environment. Copy to `.env`. Leave blank to run in MOCK mode.
# ===========================================================================

# --- LLMs -------------------------------------------------------------------
GOOGLE_API_KEY=                 # Gemini 2.5 Flash (supervisor/eligibility/tracker)
SERPER_API_KEY=                 # Google search via serper.dev (university discovery)
TAVILY_API_KEY=                 # alternative web search for RAG fallback
HUGGINGFACE_TOKEN=              # to pull/push the LoRA adapter
GPTZERO_API_KEY=                # AI detection — leave blank to use local RoBERTa

# --- Model names (override defaults if needed) ------------------------------
SUPERVISOR_MODEL=gemini-2.5-flash
AGENT_MODEL=gemini-2.5-flash
BASE_SOP_MODEL=microsoft/phi-2
SOP_ADAPTER=allisamhitha/intelliadmit-sop-lora

# --- MCP server URLs (leave blank to use mock tools) ------------------------
BROWSER_MCP_URL=
GMAIL_MCP_URL=
DRIVE_MCP_URL=
PDF_MCP_URL=
SCHOLARSHIP_MCP_URL=            # DAAD scholarship DB / scholarship MCP server

# --- RAG tuning -------------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# --- LangSmith tracing ------------------------------------------------------
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=intelliadmit

# --- API auth ---------------------------------------------------------------
API_KEY=                        # set to require X-API-Key on /api/chat
